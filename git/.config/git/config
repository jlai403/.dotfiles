[init]
	defaultBranch = main

[status]
	branch = true
	showStash = true
	showUntrackedFiles = all

[core]
	compression = 9
	whitespace = error
	preloadindex = true

[diff]
	context = 3
	renames = copies
	interHunkContext = 10

[pager]
	diff = delta

[delta]
	features = side-by-side
	whitespace = error

[diff-so-fancy]
	markEmptyLines = false

[color "diff"]
	meta = black bold
	frag = magenta
	context = white
	whitespace = yellow reverse
	old = red

[push]
	autoSetupRemote = true
	default = current
	followTags = true

[pull]
	default = current
	rebase = true

[rebase]
	autostash = true
	missingCommitsCheck = warn

[log]
	abbrevCommit = true
	graphColors = blue,yellow,cyan,magenta,green,red

[color "decorate"]
	HEAD = red
	branch = blue
	tag = yellow
	remoteBranch = magenta

[color "branch"]
	current = magenta
	local = default
	remote = yellow
	upstream = green
	plain = blue

[branch]
	sort = -committerdate

[tag]
	sort = -committerdate

[pager]
	branch = false
	tag = false

[alias]
	co = checkout
	ci = commit
	br = branch
	st = status
  sweep = "!git branch --merged | grep -v ^\\* | grep -v main | grep -v master | xargs -r git branch -d"
	tidy = "!sh -c '\n  git worktree prune\n\n  git worktree list --porcelain \\\n    | awk \"/^worktree /{wt=\\$2} /^branch /{br=\\$2; print wt, br}\" \\\n    | grep -v \"^$(git rev-parse --show-toplevel) \" \\\n    | while read wt br; do\n        branch=\"${br#refs/heads/}\"\n        if git branch --merged main 2>/dev/null | grep -qE \"^[* +]+${branch}$\"; then\n          git worktree remove \"$wt\" --force\n          echo \"removed worktree: $wt ($branch)\"\n        fi\n      done\n\n  git branch --merged main \\\n    | grep -v \"^\\*\" \\\n    | grep -vE \"^[* +]*(main|master)$\" \\\n    | grep . \\\n    | sed \"s/^[* +]*//\" \\\n    | while read b; do\n        git branch -d \"$b\" 2>/dev/null && echo \"deleted branch: $b\" || true\n      done\n'"

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
