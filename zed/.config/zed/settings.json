// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "right",
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "vim_mode": true,
  "agent": {
    "dock": "left",
    "enabled": true,
    "button": true,
    "favorite_models": [],
    "model_parameters": [],
  },
  "preview_tabs": {
    "enabled": false,
  },
  "tab_bar": {
    "show": false,
  },
  "relative_line_numbers": "enabled",
  "sticky_scroll": {
    "enabled": true,
  },
  "vertical_scroll_margin": 8.0,
  "gutter": {
    "line_numbers": true,
  },
  "max_tabs": 1,
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New", "monospace"],
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "file_types": {
    "jinja-sql": ["*.sql"],
  },
  "show_whitespaces": "all",
  "tab_size": 2,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Tokyo Night",
  },
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "/Users/jlai/.config/zed/zed-tmux.sh",
        "args": ["--login"],
      },
    },
  },
}
